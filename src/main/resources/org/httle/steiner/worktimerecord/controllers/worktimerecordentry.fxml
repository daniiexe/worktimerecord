<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.httle.steiner.worktimerecord.controllers.WorkTimeRecordEntryController">
    <children>
        <Label text="Arbeitszeit erfassen">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>

        <GridPane hgap="10.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints minWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Mitarbeiter ID:" GridPane.rowIndex="0" />
                <TextField fx:id="txtId" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Vorname:" GridPane.rowIndex="1" />
                <TextField fx:id="txtVorname" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Nachname:" GridPane.rowIndex="2" />
                <TextField fx:id="txtNachname" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Projekt:" GridPane.rowIndex="3" />
                <TextField fx:id="txtProjekt" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Datum:" GridPane.rowIndex="4" />
                <DatePicker fx:id="dpDatum" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></DatePicker>

                <Label text="Start-Zeit:" GridPane.rowIndex="5" />
                <TextField fx:id="txtStart" promptText="hh:mm" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label text="End-Zeit:" GridPane.rowIndex="6" />
                <TextField fx:id="txtEnd" promptText="hh:mm" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <Label text="Pause-Zeit:" GridPane.rowIndex="7" />
                <TextField fx:id="txtPause" promptText="mm" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                <Label text="Aufgaben:" GridPane.rowIndex="8" />
                <TextArea fx:id="txtAufgaben" prefHeight="60.0" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                <Label text="Notizen:" GridPane.rowIndex="9" />
                <TextArea fx:id="txtNotizen" prefHeight="60.0" GridPane.columnIndex="1" GridPane.rowIndex="9" />
            </children>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button fx:id="btnCancel" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Abbrechen">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
                <Button prefWidth="100.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="Speichern">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
