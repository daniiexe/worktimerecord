<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" prefHeight="1080" prefWidth="1920" stylesheets="@styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.httle.steiner.worktimerecord.controllers.WorkTimeRecordController">
    <children>
        <MenuBar fx:id="menuBar" VBox.vgrow="NEVER">
            <menus>
                <Menu fx:id="menuFile" text="File">
                    <items>
                        <MenuItem fx:id="menuItemExport" text="Export" />
                        <MenuItem fx:id="menuItemClear" text="Clear entries" />
                        <MenuItem fx:id="menuItemRefresh" text="Refresh entries" />
                        <SeparatorMenuItem />
                        <MenuItem fx:id="menuItemExit" text="Exit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <VBox alignment="TOP_CENTER" spacing="15.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="40.0" right="40.0" top="15.0" />
            </padding>

            <children>
                <VBox maxWidth="1500" spacing="15.0" VBox.vgrow="ALWAYS">
                    <children>

                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Label fx:id="lbHoursSummary" maxWidth="Infinity" prefHeight="100" styleClass="lb-header" text="NULL" HBox.hgrow="ALWAYS">
                                    <padding><Insets left="20.0" /></padding>
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Label fx:id="lbHoursWorked" maxWidth="Infinity" prefHeight="100" styleClass="lb-header" text="NULL" HBox.hgrow="ALWAYS">
                                    <padding><Insets left="20.0" /></padding>
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Label fx:id="lbHoursRest" maxWidth="Infinity" prefHeight="100" styleClass="lb-header" text="NULL" HBox.hgrow="ALWAYS">
                                    <padding><Insets left="20.0" /></padding>
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                            </children>
                        </HBox>

                        <Button fx:id="btnEntry" defaultButton="true" maxWidth="Infinity" mnemonicParsing="false" prefHeight="45" text="Enter entry">
                            <font><Font name="System Bold" size="16.0" /></font>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>

                        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label fx:id="lnLastEntries" text="Last entries:">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>

                                <TableView fx:id="workTimeTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colMID" text="MID" />
                                        <TableColumn fx:id="colLastname" text="Lastname" />
                                        <TableColumn fx:id="colFirstname" text="Firstname" />
                                        <TableColumn fx:id="colProject" text="Project" />
                                        <TableColumn fx:id="colDate" text="Date" />
                                        <TableColumn fx:id="colStart" text="Start" />
                                        <TableColumn fx:id="colEnd" text="End" />
                                        <TableColumn fx:id="colPause" text="Pause" />
                                        <TableColumn fx:id="colAssignment" text="Assignment" />
                                        <TableColumn fx:id="colNotes" text="Notes" />
                                    </columns>
                                    <placeholder>
                                        <Label fx:id="tvPlaceholder" text="No content in table view!" />
                                    </placeholder>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>