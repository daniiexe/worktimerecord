<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.httle.steiner.worktimerecord.controllers.WorkTimeRecordController" stylesheets="@styles/style.css">
    <children>
        <MenuBar fx:id="menuBar" VBox.vgrow="NEVER">
            <menus>
                <Menu fx:id="menuFile" text="File">
                    <items>
                        <MenuItem fx:id="menuItemExport" text="Export" />
                        <MenuItem fx:id="menuItemClear" text="Clear entries" />
                        <MenuItem fx:id="menuItemRefresh" text="Refresh entries" />
                        <SeparatorMenuItem />
                        <MenuItem fx:id="menuItemExit" text="Exit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
        
        <AnchorPane VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER" prefHeight="90.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="10.0">
                    <children>
                        <Label fx:id="lbHoursSummary" alignment="CENTER" prefHeight="60.0" prefWidth="400.0" text="NULL" styleClass="lb-header">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <HBox.margin><Insets left="15.0" right="15.0" /></HBox.margin>
                        </Label>
                        <Label fx:id="lbHoursWorked" alignment="CENTER" prefHeight="60.0" prefWidth="400.0" text="NULL" styleClass="lb-header">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <HBox.margin><Insets left="15.0" right="15.0" /></HBox.margin>
                        </Label>
                        <Label fx:id="lbHoursRest" alignment="CENTER" prefHeight="60.0" prefWidth="400.0" text="NULL" styleClass="lb-header">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <HBox.margin><Insets left="15.0" right="15.0" /></HBox.margin>
                        </Label>
                    </children>
                </HBox>

                <VBox spacing="10.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="155.0" AnchorPane.rightAnchor="155.0" AnchorPane.topAnchor="110.0">
                    <children>
                        <Button fx:id="btnEntry" defaultButton="true" maxWidth="Infinity" minHeight="50.0" mnemonicParsing="false" prefHeight="50.0" text="Enter working hours" VBox.vgrow="NEVER">
                            <font><Font size="14.0" /></font>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>

                        <Label text="Last entries:">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Label>

                        <TableView fx:id="workTimeTable" prefHeight="900" prefWidth="800.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colMID" prefWidth="50.0" text="MID" styleClass="tv-col"/>
                                <TableColumn fx:id="colLastname" prefWidth="150.0" text="Lastname" styleClass="tv-col"/>
                                <TableColumn fx:id="colFirstname" prefWidth="150.0" text="Firstname" styleClass="tv-col"/>
                                <TableColumn fx:id="colProject" prefWidth="150.0" text="Project" styleClass="tv-col"/>
                                <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" styleClass="tv-col"/>
                                <TableColumn fx:id="colStart" prefWidth="150.0" text="Start" styleClass="tv-col"/>
                                <TableColumn fx:id="colEnd" prefWidth="150.0" text="End" styleClass="tv-col"/>
                                <TableColumn fx:id="colPause" prefWidth="150.0" text="Pause" styleClass="tv-col"/>
                                <TableColumn fx:id="colAssignment" prefWidth="200.0" text="Assignment" styleClass="tv-col"/>
                                <TableColumn fx:id="colNotes" prefWidth="200.0" text="Notes" styleClass="tv-col"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</VBox>
